# Database
DATABASE_URL="postgresql://user:pass@host/db"

# Auth (generate via: openssl rand -hex 32)
AUTH_SECRET="your-secret-here"

# App URL
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Seed credentials (used by prisma/seed.ts)
ADMIN_EMAIL="admin@kairos.com"
ADMIN_PASSWORD="admin123"
SEED_USER_EMAIL="samuel@example.com"
SEED_USER_PASSWORD="user123"

# Email (SMTP)
SMTP_HOST="mail.yourdomain.com"
SMTP_PORT="587"
SMTP_USER="noreply@yourdomain.com"
SMTP_PASS="your-smtp-password"
SMTP_FROM="noreply@yourdomain.com"

# Google OAuth (create at https://console.cloud.google.com)
AUTH_GOOGLE_ID="your-google-client-id"
AUTH_GOOGLE_SECRET="your-google-client-secret"

# Optional: Payment (Paystack)
# PAYSTACK_SECRET_KEY="sk_..."
